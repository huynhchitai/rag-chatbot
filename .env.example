# --- Vertex AI (Google Cloud) ---
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# Pick ONE of the three options for credentials (in priority order):
#
# 1) FILE PATH — easiest for local dev. Point to your downloaded service-account JSON.
#    Save the file outside the repo OR make sure .env* is in .gitignore.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/key.json
#
# 2) BASE64 — easiest to paste into Vercel UI. Generate with:
#      base64 -w 0 < key.json
# GOOGLE_APPLICATION_CREDENTIALS_B64=eyJ0eXBlIjoi...
#
# 3) INLINE JSON — must be a SINGLE LINE (escape sequences \n stay as 2 chars).
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Upstash Redis (rate limit) — optional locally ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vercel cron auth ---
CRON_SECRET=replace-with-a-long-random-string
