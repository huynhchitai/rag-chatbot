# ==============================================================================
# rag-chatbot — environment
# ==============================================================================

# --- Google Cloud (Vertex AI for embeddings + Gemini) ---
# On Cloud Run: auth is automatic via the service account's IAM
# (roles/aiplatform.user). No key needed in env.
# Locally: set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-key.json

# --- Supabase (Postgres + pgvector for chunks/documents) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate limiting — no-op if unset) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Bearer token for the daily /api/cleanup cron ---
CRON_SECRET=
